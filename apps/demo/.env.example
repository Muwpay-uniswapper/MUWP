# Stellar secret key for subscriber server-side signing
# This key signs Soroban transactions. In production, use a vault.
STELLAR_SECRET=S...

# Network: "testnet" or "mainnet" (default: mainnet)
STELLAR_NETWORK=testnet

# Soroban contract ID
# Testnet:  CAH3T7NSZMZTX2KPKK5IKKMCKE4ZDYVK4OO64OISB6OY7W3OLS6OJJMP
# Mainnet:  CC76NWELMDVXHFU7T62KJQ2UI6EPHPVG25C65EIIP7R6CPEFITTDZXPA
CONTRACT_ID=CAH3T7NSZMZTX2KPKK5IKKMCKE4ZDYVK4OO64OISB6OY7W3OLS6OJJMP

# Soroban RPC endpoint (auto-detected from STELLAR_NETWORK if not set)
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://soroban-rpc.stellar.org
# SOROBAN_RPC_URL=

# MUWP API base URL
MUWP_BASE_URL=https://muwp.xyz
